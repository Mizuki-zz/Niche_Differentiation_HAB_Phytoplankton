# 9. 保存可视化结果
ggsave("link_strength_stacked_bar.pdf", stacked_bar_plot, width = 10, height = 8)
# Load necessary packages
library(readxl)
library(dplyr)
library(ggplot2)
library(purrr)
library(tibble)
library(scales)
library(ggpubr)
# Custom parameter settings
THRESHOLD <- 0  # Interaction coefficient threshold
# Season-specific color settings
SEASON_COLORS <- c(
spring = "#ff6666",  # Spring: light red
summer = "#6699cc",  # Summer: light blue
autumn = "#cc9900"   # Autumn: golden yellow
)
# Interaction strength level colors
POS_COLORS <- c("#FFC107", "#FF9800", "#FF5722")  # Positive: weak, medium, strong
NEG_COLORS <- c("#4FC3F7", "#2196F3", "#0D47A1")  # Negative: weak, medium, strong
# 1. Read all season data and calculate global quantiles
seasons <- c("spring", "summer", "autumn")
all_weights <- numeric(0)
for(season in seasons){
file_name <- paste0("InterMatrix_", season, "_results.xlsx")
beta_matrix <- read_excel(file_name) %>%
column_to_rownames(var = "Species") %>%
as.matrix()
diag(beta_matrix) <- 0
beta_matrix[abs(beta_matrix) <= THRESHOLD] <- 0
season_weights <- abs(beta_matrix[beta_matrix != 0])
all_weights <- c(all_weights, season_weights)
}
# Unified classification standard (Winsorization for extreme values)
upper_bound <- quantile(all_weights, probs = 0.99, na.rm = TRUE)
trimmed_weights <- pmin(all_weights, upper_bound)
global_quantiles <- quantile(
trimmed_weights,
probs = c(0.33, 0.67),
na.rm = TRUE
)
# 2. Calculate link percentages for each season
calculate_link_percentages <- function(season, quantiles) {
file_name <- paste0("InterMatrix_", season, "_results.xlsx")
beta_matrix <- read_excel(file_name) %>%
column_to_rownames(var = "Species") %>%
as.matrix()
diag(beta_matrix) <- 0
filtered_matrix <- beta_matrix
filtered_matrix[abs(filtered_matrix) <= THRESHOLD] <- 0
valid_species <- colnames(filtered_matrix)[colSums(abs(filtered_matrix)) > 0]
filtered_matrix <- filtered_matrix[valid_species, valid_species]
edges <- data.frame()
for (i in rownames(filtered_matrix)) {
for (j in colnames(filtered_matrix)) {
beta <- filtered_matrix[i, j]
if (beta != 0) {
edges <- rbind(edges, data.frame(
from = j,
to = i,
weight = beta,
abs_weight = abs(beta)
))
}
}
}
# Classify link strength
edges$level <- case_when(
edges$abs_weight <= quantiles[1] ~ "weak",
edges$abs_weight <= quantiles[2] ~ "medium",
TRUE ~ "strong"
)
edges$type <- ifelse(edges$weight > 0, "positive", "negative")
# Calculate total
total_links <- nrow(edges)
# Calculate percentage for each category
percentages <- edges %>%
group_by(type, level) %>%
summarise(count = n(), .groups = 'drop') %>%
mutate(percentage = count / total_links * 100) %>%
mutate(category = paste(type, level, sep = "_"))
# Ensure all categories exist (even if count is 0)
all_categories <- expand.grid(
type = c("positive", "negative"),
level = c("weak", "medium", "strong")
) %>%
mutate(category = paste(type, level, sep = "_"))
percentages <- all_categories %>%
left_join(percentages, by = c("type", "level", "category")) %>%
mutate(
count = ifelse(is.na(count), 0, count),
percentage = ifelse(is.na(percentage), 0, percentage)
)
return(list(
season = season,
percentages = percentages,
total_links = total_links
))
}
# 3. Calculate link percentages for all seasons
season_percentages <- map(seasons, ~calculate_link_percentages(.x, global_quantiles))
names(season_percentages) <- seasons
# 4. Output detailed percentage results
cat("Link Strength Percentage Distribution by Season:\n\n")
for(season in seasons) {
cat(sprintf("=== %s Season ===\n", season))
cat(sprintf("Total Links: %d\n", season_percentages[[season]]$total_links))
percentages_df <- season_percentages[[season]]$percentages
for(i in 1:nrow(percentages_df)) {
row <- percentages_df[i, ]
cat(sprintf("%s %s: %.2f%% (%d links)\n",
row$type, row$level,
row$percentage, row$count))
}
cat("\n")
}
# 5. Prepare visualization data
viz_data <- map_dfr(seasons, function(season) {
percentages_df <- season_percentages[[season]]$percentages %>%
mutate(season = season)
return(percentages_df)
})
# Add English labels and set factor levels for proper ordering
viz_data <- viz_data %>%
mutate(
type_label = factor(type, levels = c("positive", "negative"),
labels = c("Positive", "Negative")),
level_label = factor(level, levels = c("weak", "medium", "strong"),
labels = c("Weak", "Medium", "Strong")),
season_label = factor(season, levels = c("spring", "summer", "autumn"),
labels = c("Spring", "Summer", "Autumn"))
)
# 6. Create stacked bar plot visualization
stacked_bar_plot <- ggplot(viz_data, aes(x = season_label, y = percentage, fill = interaction(type, level))) +
geom_bar(stat = "identity", position = "stack", color = "white", linewidth = 0.3) +
scale_fill_manual(
name = "Link Type",
values = c(
"positive.weak" = POS_COLORS[1],
"positive.medium" = POS_COLORS[2],
"positive.strong" = POS_COLORS[3],
"negative.weak" = NEG_COLORS[1],
"negative.medium" = NEG_COLORS[2],
"negative.strong" = NEG_COLORS[3]
),
labels = c(
"positive.weak" = "Positive Weak",
"positive.medium" = "Positive Medium",
"positive.strong" = "Positive Strong",
"negative.weak" = "Negative Weak",
"negative.medium" = "Negative Medium",
"negative.strong" = "Negative Strong"
)
) +
labs(
title = "Link Strength Distribution by Season",
x = "Season",
y = "Percentage (%)"
) +
theme_minimal() +
theme(
text = element_text(family = "Arial", size = 12),
plot.title = element_text(hjust = 0.5, face = "bold", size = 16),
axis.text = element_text(size = 11),
legend.position = "right",
legend.text = element_text(size = 10)
) +
geom_text(aes(label = sprintf("%.1f%%", percentage)),
position = position_stack(vjust = 0.5),
size = 3.5, color = "white", fontface = "bold", family = "Arial")
# 7. Create faceted pie chart visualization
pie_plot <- ggplot(viz_data, aes(x = "", y = percentage, fill = interaction(type, level))) +
geom_bar(stat = "identity", width = 1, color = "white") +
coord_polar("y", start = 0) +
scale_fill_manual(
name = "Link Type",
values = c(
"positive.weak" = POS_COLORS[1],
"positive.medium" = POS_COLORS[2],
"positive.strong" = POS_COLORS[3],
"negative.weak" = NEG_COLORS[1],
"negative.medium" = NEG_COLORS[2],
"negative.strong" = NEG_COLORS[3]
),
labels = c(
"positive.weak" = "Positive Weak",
"positive.medium" = "Positive Medium",
"positive.strong" = "Positive Strong",
"negative.weak" = "Negative Weak",
"negative.medium" = "Negative Medium",
"negative.strong" = "Negative Strong"
)
) +
facet_wrap(~season_label, nrow = 1) +
labs(
title = "Link Strength Distribution (Pie Chart) by Season"
) +
theme_void() +
theme(
text = element_text(family = "Arial", size = 12),
plot.title = element_text(hjust = 0.5, face = "bold", size = 16),
legend.position = "bottom",
strip.text = element_text(size = 12, face = "bold", family = "Arial")
) +
geom_text(aes(label = ifelse(percentage > 5, sprintf("%.1f%%", percentage), "")),
position = position_stack(vjust = 0.5),
size = 3.5, color = "white", fontface = "bold", family = "Arial")
# 8. Create grouped bar plot visualization (positive and negative links separated)
grouped_bar_plot <- ggplot(viz_data, aes(x = level_label, y = percentage, fill = type_label)) +
geom_bar(stat = "identity", position = "dodge", color = "white", linewidth = 0.3) +
facet_wrap(~season_label, nrow = 1) +
scale_fill_manual(
name = "Link Type",
values = c("Positive" = "#FF9800", "Negative" = "#2196F3")
) +
labs(
title = "Positive and Negative Link Strength Distribution by Season",
x = "Strength Level",
y = "Percentage (%)"
) +
theme_minimal() +
theme(
text = element_text(family = "Arial", size = 12),
plot.title = element_text(hjust = 0.5, face = "bold", size = 16),
axis.text = element_text(size = 11),
legend.position = "top",
strip.text = element_text(size = 12, face = "bold", family = "Arial")
) +
geom_text(aes(label = sprintf("%.1f%%", percentage)),
position = position_dodge(width = 0.9),
vjust = -0.5, size = 3.5, family = "Arial")
# 9. Save visualization results
ggsave("link_strength_stacked_bar.pdf", stacked_bar_plot, width = 10, height = 8)
