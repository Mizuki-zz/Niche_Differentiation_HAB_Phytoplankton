# 10. Create summary table and save as Excel
summary_table <- viz_data %>%
select(season_label, type_label, level_label, percentage, count) %>%
rename(Season = season_label, Type = type_label, Level = level_label,
Percentage = percentage, Count = count) %>%
arrange(Season, Type, Level)
# Create Excel workbook with multiple sheets
wb <- createWorkbook()
# Add summary table
addWorksheet(wb, "Link Strength Percentages")
writeData(wb, "Link Strength Percentages", summary_table)
# Add detailed data for each season
for(season in seasons) {
season_data <- season_percentages[[season]]$percentages %>%
mutate(Season = season) %>%
select(Season, Type = type, Level = level, Count = count, Percentage = percentage)
sheet_name <- paste0(toupper(substr(season, 1, 1)), substr(season, 2, nchar(season)))
addWorksheet(wb, sheet_name)
writeData(wb, sheet_name, season_data)
}
# Add global quantiles information
quantiles_df <- data.frame(
Level = c("Weak", "Medium", "Strong"),
Threshold = c(
paste0("≤ ", round(global_quantiles[1], 4)),
paste0(round(global_quantiles[1], 4), " - ", round(global_quantiles[2], 4)),
paste0("> ", round(global_quantiles[2], 4))
)
)
addWorksheet(wb, "Classification Thresholds")
writeData(wb, "Classification Thresholds", quantiles_df)
# Save the Excel file
saveWorkbook(wb, "link_strength_analysis.xlsx", overwrite = TRUE)
# 11. Output global quantile information
cat("\nGlobal Classification Standards:\n")
cat(sprintf("Weak: ≤ %.4f\n", global_quantiles[1]))
cat(sprintf("Medium: %.4f - %.4f\n", global_quantiles[1], global_quantiles[2]))
cat(sprintf("Strong: > %.4f\n", global_quantiles[2]))
cat("\nFiles generated:\n")
cat("- link_strength_stacked_bar.pdf: Stacked bar plot\n")
cat("- link_strength_pie_charts.pdf: Faceted pie charts\n")
cat("- link_strength_grouped_bar.pdf: Grouped bar plot\n")
cat("- link_strength_analysis.xlsx: Excel file with detailed data\n")
